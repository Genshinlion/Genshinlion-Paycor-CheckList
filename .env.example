# ── Twilio (SMS) ────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+15550000000

# ── Paycor API ──────────────────────────────────────────────
PAYCOR_CLIENT_ID=your_client_id
PAYCOR_CLIENT_SECRET=your_client_secret
PAYCOR_SUBSCRIPTION_KEY=your_apim_key
PAYCOR_LEGAL_ENTITY_ID=your_legal_entity_id

# ── Supabase (backup accounts + local auth) ─────────────────
# Get these from: Supabase dashboard → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6Ikp...  # Secret — NEVER expose in frontend
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6Ikp...    # Safe for frontend use

# ── App ─────────────────────────────────────────────────────
APP_URL=https://your-site.netlify.app
MANAGER_PHONE=+15559990001
